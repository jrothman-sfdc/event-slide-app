# Google Cloud API key with Slides API and Drive API enabled
GOOGLE_API_KEY=your_google_api_key_here

# PostgreSQL connection string (set automatically by Heroku Postgres add-on)
DATABASE_URL=postgresql://user:password@localhost:5432/slideshowdb

# Set to "production" on Heroku
NODE_ENV=development

# Port (set automatically by Heroku)
PORT=3000
