# Google OAuth credentials (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Must match an authorized redirect URI in your Google Cloud OAuth client
# Local dev:  http://localhost:3000/auth/callback
# Production: https://your-app.herokuapp.com/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# PostgreSQL connection string (set automatically by Heroku Postgres add-on)
DATABASE_URL=postgresql://user:password@localhost:5432/slideshowdb

# Set to "production" on Heroku
NODE_ENV=development

# Port (set automatically by Heroku)
PORT=3000
